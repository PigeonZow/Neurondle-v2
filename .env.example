# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (never expose to client)
# Find this in Supabase Dashboard > Settings > API > service_role (click Reveal)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Neuronpedia API (optional - for higher rate limits)
NEURONPEDIA_API_KEY=sk-np-your-key

# Puzzle Generation Settings
MIN_EXPLANATION_SCORE=0.7
MAX_FEATURE_HISTORY=100
